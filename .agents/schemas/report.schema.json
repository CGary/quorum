{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "report.schema.json",
  "title": "Report Artifact Schema",
  "description": "Validation schema for Quorum report artifacts",
  "type": "object",
  "properties": {
    "meta": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "schemaVersion": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "schemaVersion",
        "date"
      ],
      "additionalProperties": false
    },
    "summary": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low",
              "info"
            ]
          }
        },
        "required": [
          "id",
          "description",
          "severity"
        ],
        "additionalProperties": false
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "findingId": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "details": {
            "type": "string"
          }
        },
        "required": [
          "findingId",
          "path",
          "details"
        ],
        "additionalProperties": false
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "impact": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "description",
          "impact"
        ],
        "additionalProperties": false
      }
    },
    "actionPlan": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "step": {
            "type": "integer"
          },
          "action": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          }
        },
        "required": [
          "step",
          "action",
          "owner"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "meta",
    "summary",
    "findings",
    "evidence",
    "risks",
    "actionPlan"
  ],
  "additionalProperties": false
}
