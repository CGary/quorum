{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "blueprint.schema.json",
  "title": "Quorum Surgical Blueprint",
  "type": "object",
  "required": [
    "task_id",
    "summary",
    "affected_files",
    "symbols",
    "dependencies",
    "test_scenarios"
  ],
  "additionalProperties": false,
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[A-Z]+-[0-9]+"
    },
    "summary": {
      "type": "string",
      "maxLength": 200,
      "minLength": 1
    },
    "affected_files": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "symbols": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "test_scenarios": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "strategy": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "step",
          "action"
        ],
        "additionalProperties": false,
        "properties": {
          "step": {
            "type": "integer",
            "minimum": 1
          },
          "action": {
            "type": "string",
            "minLength": 5
          },
          "files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
