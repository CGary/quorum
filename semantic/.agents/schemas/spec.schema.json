{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "spec.schema.json",
  "title": "Quorum Task Specification",
  "type": "object",
  "required": [
    "task_id",
    "summary",
    "goal",
    "invariants",
    "acceptance"
  ],
  "additionalProperties": false,
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[A-Z]+-[0-9]+"
    },
    "summary": {
      "type": "string",
      "maxLength": 200,
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 10
    },
    "invariants": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "acceptance": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "risk": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "non_goals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
